# Sao chép thành .env rồi điền giá trị thật (KHÔNG commit .env lên git)

# --- Webhook ---
# Chuỗi tùy ý anh tự đặt, nhập y hệt khi đăng ký webhook trên App Dashboard
VERIFY_TOKEN=cent_beauty_2026_secret

# --- Database ---
DATABASE_URL=postgresql://cent:doi_mat_khau_manh@db:5432/cent_inbox

# --- Báo cáo / múi giờ tính khoảng ngày ---
REPORT_TZ=Asia/Ho_Chi_Minh

# --- Bảo vệ API (để trống = không yêu cầu key; NÊN đặt khi production) ---
