ORDERS_API_KEY=                  # bảo vệ endpoint GHI: /api/orders, /api/link, /api/backfill-phones

# --- Đồng bộ quảng cáo (ads_sync.py) ---
META_ACCESS_TOKEN=               # token System User, quyền ads_read, KHÔNG hết hạn
