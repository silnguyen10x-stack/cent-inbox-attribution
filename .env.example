# Sao chép thành .env rồi điền giá trị thật (KHÔNG commit .env lên git)

# Chuỗi tùy ý anh tự đặt, nhập y hệt khi đăng ký webhook trên App Dashboard
VERIFY_TOKEN=cent_beauty_2026_secret

# Kết nối PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/cent_inbox

# Token System User cho từng page, dạng JSON: {"<page_id>":"<token>", ...}
PAGE_TOKENS={"1112223334445556":"EAAG...","9998887776665554":"EAAG..."}
